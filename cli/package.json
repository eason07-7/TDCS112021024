{
  "name": "tdcs-dl",
  "version": "0.1.0",
  "description": "TDCS 自動下載 + 清洗 CLI 工具 — 幫 TDCS 研究者跳過前置苦工",
  "type": "module",
  "bin": {
    "tdcs-dl": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.600.0",
    "@aws-sdk/client-lambda": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "gradient-string": "^2.0.2",
    "ink": "^4.4.1",
    "ora": "^5.4.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/gradient-string": "^1.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
